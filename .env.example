# ╔══════════════════════════════════════════════════════╗
# ║ FICHFLOW — Variables d'environnement                ║
# ║ Copiez ce fichier en .env.local et remplissez        ║
# ║ les valeurs avant de lancer le projet                ║
# ╚══════════════════════════════════════════════════════╝

# ============================================
# SUPABASE (Auth + Storage)
# dashboard.supabase.com → Settings → API
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================
# BASE DE DONNÉES (Prisma / PostgreSQL)
# dashboard.supabase.com → Settings → Database → Connection string
# ============================================
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-x-eu-west-x.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-x-eu-west-x.pooler.supabase.com:5432/postgres"

# ============================================
# ANTHROPIC (IA)
# console.anthropic.com → API Keys
# ============================================
ANTHROPIC_API_KEY=sk-ant-api03-...

# ============================================
# STRIPE (Paiements)
# dashboard.stripe.com → Developers → API Keys
# ============================================
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — dashboard.stripe.com → Products
STRIPE_ARTISAN_MONTHLY_PRICE_ID=price_...
STRIPE_ARTISAN_YEARLY_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...

# Packs de crédits
STRIPE_PACK_10_PRICE_ID=price_...
STRIPE_PACK_50_PRICE_ID=price_...
STRIPE_PACK_150_PRICE_ID=price_...
STRIPE_PACK_300_PRICE_ID=price_...

# ============================================
# RESEND (Emails transactionnels)
# resend.com → API Keys
# ============================================
RESEND_API_KEY=re_...
ADMIN_EMAIL=contact@guyon-informatique-web.fr
EMAIL_FROM=FichFlow <noreply@fichflow.fr>

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FichFlow

# ============================================
# CRON (sécurisation des routes cron)
# Générer : openssl rand -hex 32
# ============================================
CRON_SECRET=votre_secret_aleatoire

# ============================================
# INTÉGRATION FACTUPILOT (sync inter-SaaS)
# ============================================
FACTUPILOT_SYNC_URL=https://factupilot.fr
FACTUPILOT_APP_KEY=fp_app_...
